{# src/_includes/lp-header.njk — header minimalista, usado em landing pages (ex.: technical-review) #}
<header class="lp-header">
    <nav class="lp-nav">
        <a href="/" class="lp-logo" aria-label="Back to SIPOP homepage">
            <img src="/assets/images/logo/Logo1.webp" alt="SIPOP" class="brand-logo brand-logo--light" style="height:40px;">
            <img src="/assets/images/logo/Logo2.webp" alt="SIPOP" class="brand-logo brand-logo--dark" style="height:40px;">
        </a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <span class="theme-toggle__icon theme-toggle__icon--sun">☀️</span>
            <span class="theme-toggle__icon theme-toggle__icon--moon">🌙</span>
            <span class="theme-toggle__icon theme-toggle__icon--system">⚙️</span>
        </button>
    </nav>
</header>
