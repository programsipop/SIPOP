<!-- ========== ETHICAL DISCLAIMER ========== -->
<section class="ethical-disclaimer">
    <div class="container">
        <div class="disclaimer-box">
            <h4>Ethical Disclaimer</h4>
            <p>SIPOP is a scientific governance and oversight program. We do not provide ghostwriting services, data fabrication, or guaranteed publication. Our role is to audit methodology, enhance statistical integrity, and ensure compliance with international reporting standards (PRISMA, CONSORT, GRADE). All final intellectual and ethical responsibilities remain with the authors.</p>
        </div>
    </div>
</section>
